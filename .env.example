# ===========================================
# VPS Docker Swarm Configuration
# ===========================================
# Copy to .env and update all values:
#   cp .env.example .env
# ===========================================

# Domain (pakeisk į savo domeną)
DOMAIN=example.com
ACME_EMAIL=admin@example.com

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_pg_strong_password
POSTGRES_DB=default

# PostgreSQL - servisų duombazės
ROUNDCUBE_DB_PASSWORD=CHANGE_ME_roundcube_db_password
GRAFANA_DB_PASSWORD=CHANGE_ME_grafana_db_password
POSTGRES_EXPORTER_PASSWORD=CHANGE_ME_exporter_password

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# IP Whitelist admin tools (Portainer, Adminer, Grafana, Prometheus, Dozzle, Traefik dashboard)
# Kableliu atskirti IP su CIDR (pvz: 1.2.3.4/32,5.6.7.8/32)
# Valdyk per: ./server.sh whitelist myip
ADMIN_WHITELIST_IPS=127.0.0.1/32

# Mail (naudoja DOMAIN kintamąjį)
