# Pickzy Food — Production Environment
# Copy to .env and fill in values: cp .env.example .env

# App
APP_URL=https://api.pickzy.app
APP_KEY=
FRONTEND_URL=

# Images
IMAGE_TAG=latest

# Database (core stack — create via: ./server.sh db create pickzy_food)
PICKZY_DB_PASSWORD=

# Redis (same as core stack REDIS_PASSWORD)
REDIS_PASSWORD=

# Playwright (same as core stack PLAYWRIGHT_TOKEN)
PLAYWRIGHT_TOKEN=

# Storage
FILESYSTEM_DISK=r2
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=
CLOUDFLARE_R2_ENDPOINT=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@pickzy.app

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Monitoring
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
