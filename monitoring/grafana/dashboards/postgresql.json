{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "Statusas",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }]
        }
      },
      "targets": [{ "expr": "pg_up", "legendFormat": "PostgreSQL" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "Aktyvūs prisijungimai",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 200,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 160 }
            ]
          }
        }
      },
      "targets": [{ "expr": "sum(pg_stat_activity_count)", "legendFormat": "Connections" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "title": "DB dydis (visos)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "expr": "sum(pg_database_size_bytes)", "legendFormat": "Total" }]
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "title": "Transactions/s",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [{ "expr": "sum(rate(pg_stat_database_xact_commit[5m])) + sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "TX/s" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "title": "Prisijungimai per DB",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pg_stat_activity_count{datname!=\"\"}", "legendFormat": "{{datname}} ({{state}})" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "title": "DB dydis",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "expr": "pg_database_size_bytes{datname!~\"template.*\"}", "legendFormat": "{{datname}}" }]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "title": "Commits vs Rollbacks",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{datname!~\"template.*\"}[5m]))", "legendFormat": "{{datname}} commits" },
        { "expr": "-sum by (datname) (rate(pg_stat_database_xact_rollback{datname!~\"template.*\"}[5m]))", "legendFormat": "{{datname}} rollbacks" }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "title": "Cache hit ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [{
        "expr": "sum by (datname) (pg_stat_database_blks_hit{datname!~\"template.*\"}) / (sum by (datname) (pg_stat_database_blks_hit{datname!~\"template.*\"}) + sum by (datname) (pg_stat_database_blks_read{datname!~\"template.*\"}))",
        "legendFormat": "{{datname}}"
      }]
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "id": 9,
      "title": "Deadlocks",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "increase(pg_stat_database_deadlocks[5m])",
        "legendFormat": "{{datname}}"
      }]
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "title": "Temp bytes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [{
        "expr": "rate(pg_stat_database_temp_bytes[5m])",
        "legendFormat": "{{datname}}"
      }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["postgresql", "database"],
  "time": { "from": "now-3h", "to": "now" },
  "title": "PostgreSQL",
  "uid": "postgresql"
}
